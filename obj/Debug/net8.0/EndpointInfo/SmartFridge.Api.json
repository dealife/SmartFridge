{
  "openapi": "3.0.1",
  "info": {
    "title": "SmartFridge.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Fridge/analyze": {
      "post": {
        "tags": [
          "Fridge"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "photo": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "photo": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Fridge/save": {
      "post": {
        "tags": [
          "Fridge"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SavedRecipe"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SavedRecipe"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SavedRecipe"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Fridge/saved/{id}": {
      "delete": {
        "tags": [
          "Fridge"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Fridge/saved": {
      "get": {
        "tags": [
          "Fridge"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SavedRecipe": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "savedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  }
}